# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=0

# Database
DATABASE_URL=sqlite:///unittest.db
# For PostgreSQL: postgresql://user:password@localhost/dbname

# API Keys
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=
OCR_SPACE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Server
PORT=5000
HOST=0.0.0.0

# Email (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Vercel
VERCEL=false
VERCEL_GIT_COMMIT_SHA=
VERCEL_GIT_REPO_ID=
